digraph ML_Load_Forecasting {
    rankdir=TB;
    graph [fontname="Helvetica", splines=ortho, nodesep=0.4, ranksep=0.6];
    node  [fontname="Helvetica", shape=box, style="rounded,filled", fontsize=11];
    edge  [fontname="Helvetica", fontsize=9, color="#666666"];

    subgraph cluster_data {
        label="Data Sources";
        style=dashed;
        color="#888888";
        node [fillcolor="#E1F5EE", color="#0F6E56"];
        Load    [label="Electricity Load\nENTSO-E · hourly · Germany"];
        Weather [label="Weather Data\nTemperature · wind · radiation · wind speed"];
    }

    subgraph cluster_processing {
        label="Data Processing";
        style=dashed;
        color="#888888";
        node [fillcolor="#EEEDFE", color="#534AB7"];
        Cleaning  [label="Data Cleaning\nMissing values · outliers · time alignment"];
        EDA       [label="Exploratory Data Analysis\nPatterns · correlations · seasonality"];
        FeatEng   [label="Feature Engineering\nHour · day · month · weekend · holiday"];
        LagFeat   [label="Lag Features\nLoad t-1h · t-24h · t-168h"];
        RollFeat  [label="Rolling Features\nMean 24h · Mean 168h · Std 24h"];
    }

    subgraph cluster_ml {
        label="Machine Learning Models";
        style=dashed;
        color="#888888";
        node [fillcolor="#E6F1FB", color="#185FA5"];
        Split  [label="Train / Test Split\n2020-2022 train · 2023 test"];
        LinReg [label="Linear Regression\nBaseline"];
        RF     [label="Random Forest\nEnsemble"];
        XGB    [label="XGBoost\nGradient boosting"];
        SVM    [label="SVM\nSupport Vector Machine"];
        LSTM   [label="LSTM\nLong Short-Term Memory"];
        Tuning [label="Hyperparameter Tuning\nGridSearchCV · CrossValidation"];
    }

    subgraph cluster_results {
        label="Results";
        style=dashed;
        color="#888888";
        node [fillcolor="#FAEEDA", color="#854F0B"];
        Eval       [label="Model Evaluation\nMAE · RMSE · R²  — compare all models"];
        Importance [label="Feature Importance\nTop drivers of demand"];
        Forecast   [label="Load Forecast\n24h ahead"];
        Viz        [label="Prediction vs Actual\nVisualization"];
        Insights   [label="Demand Patterns\nEnergy insights"];
    }

    Load      -> Cleaning;
    Weather   -> Cleaning;
    Cleaning  -> EDA;
    EDA       -> FeatEng;
    FeatEng   -> LagFeat;
    LagFeat   -> RollFeat;
    RollFeat  -> Split;
    Split     -> LinReg;
    Split     -> RF;
    Split     -> XGB;
    Split     -> SVM;
    Split     -> LSTM;
    LinReg    -> Tuning;
    RF        -> Tuning;
    XGB       -> Tuning;
    SVM       -> Tuning;
    LSTM      -> Tuning;
    Tuning    -> Eval;
    Eval      -> Importance;
    Eval      -> Forecast;
    Forecast  -> Viz;
    Viz       -> Insights;
}